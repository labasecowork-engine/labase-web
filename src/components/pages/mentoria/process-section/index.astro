---
interface Step {
  title?: string;
  description?: string;
}
interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  buttonLabel?: string;
  buttonHref?: string;
  steps?: Step[];
}

const defaultSteps: Step[] = [
  {
    title: "Evaluación inicial",
    description:
      "Analizamos tu situación actual, objetivos y desafíos para diseñar un plan personalizado.",
  },
  {
    title: "Matching con mentor",
    description:
      "Te conectamos con el mentor ideal según tu industria, experiencia y objetivos específicos.",
  },
  {
    title: "Sesiones regulares",
    description:
      "Reuniones programadas donde trabajarás estrategias, resolverás dudas y planificarás acciones.",
  },
  {
    title: "Seguimiento y ajustes",
    description:
      "Evaluamos el progreso y ajustamos la estrategia según los resultados y nuevos desafíos.",
  },
];

const {
  eyebrow = "Cómo funciona",
  title = "Tu proceso de mentoría",
  description = "Un proceso estructurado y personalizado que te llevará desde donde estás ahora hasta donde quieres llegar, con el apoyo constante de expertos en tu área.",
  buttonLabel = "COMENZAR MI PROCESO",
  buttonHref = "#",
  steps,
} = Astro.props;
const items = steps && steps.length > 0 ? steps : defaultSteps;
---

<section class="bg-stone-950 py-32">
  <div class="max-w-7xl mx-auto px-8">
    <div class="text-center mb-16">
      <p class="text-stone-100 text-lg tracking-[0.35em] uppercase mb-4">
        {eyebrow}
      </p>
      <h2 class="text-stone-100 text-5xl font-bold font-secondary uppercase">
        {title}
      </h2>
      <p class="text-stone-200 mt-6 text-base tracking-wider max-w-3xl mx-auto">
        {description}
      </p>
    </div>

    <div class="grid md:grid-cols-4 gap-8 relative">
      <div
        class="w-full hidden md:block h-[1px] bg-stone-100/20 absolute top-[40px]"
      >
      </div>
      {
        items.map((_, i) => (
          <div class="md:block hidden">
            <div class="size-20 relative bg-stone-950 mx-auto border border-stone-100/30 rounded-full flex items-center justify-center">
              <span class="text-lg font-base text-stone-100">{i + 1}</span>
            </div>
          </div>
        ))
      }

      {
        items.map((step, i) => (
          <div class="text-center">
            <div class="size-20 relative bg-stone-950 mx-auto border border-stone-100/30 rounded-full flex items-center justify-center mb-8 md:mb-0 md:hidden">
              <span class="text-lg font-base text-stone-100">{i + 1}</span>
            </div>
            <h3 class="text-stone-100 text-xl font-bold font-secondary uppercase mb-4">
              {step.title}
            </h3>
            <p class="text-stone-300 text-sm tracking-wider">
              {step.description}
            </p>
          </div>
        ))
      }
    </div>

    {
      buttonLabel && (
        <div class="text-center mt-24">
          <a
            href={buttonHref}
            class="rounded-full bg-stone-100 lg:px-12 px-10 py-3 lg:py-4 text-sm font-semibold text-stone-950 shadow-xs hover:bg-stone-200 hover:text-stone-950 tracking-wider transition-all focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-stone-400"
          >
            {buttonLabel}
          </a>
        </div>
      )
    }
  </div>
</section>
