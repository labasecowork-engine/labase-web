---
interface Card {
  image?: string;
  title?: string;
  description?: string;
}
interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  cards?: Card[];
}

const defaultCards: Card[] = [
  {
    image: "/images/mentoria/2.jpg",
    title: "Mentoría 1:1",
    description:
      "Sesiones personalizadas con mentores expertos en tu área de interés, adaptadas a tus necesidades específicas y objetivos.",
  },
  {
    image: "/images/mentoria/5.jpg",
    title: "Mentoría grupal",
    description:
      "Participa en sesiones grupales donde puedes aprender de otros emprendedores y compartir experiencias valiosas.",
  },
  {
    image: "/images/mentoria/1.jpg",
    title: "Seguimiento continuo",
    description:
      "Acompañamiento constante en tu proceso de crecimiento con revisiones periódicas y ajustes de estrategia.",
  },
];

const {
  eyebrow = "Programa de mentoría",
  title = "ACELERA TU CRECIMIENTO CON EXPERTOS",
  description = "Nuestro programa de mentoría te conecta con profesionales experimentados que han recorrido el camino que tú estás empezando. Recibe orientación personalizada, estrategias probadas y el apoyo que necesitas para superar obstáculos y alcanzar tus metas más rápido.",
  cards = defaultCards,
} = Astro.props;
const items = cards && cards.length > 0 ? cards : defaultCards;
---

<section class="pt-12 md:pt-24">
  <div class="max-w-7xl mx-auto w-full px-8">
    <p class="text-stone-600 text-lg tracking-[0.35em] uppercase mb-4 text-left">
      {eyebrow}
    </p>
    <h2
      class="text-stone-950 text-5xl font-bold font-secondary uppercase text-left max-w-5xl"
    >
      {title}
    </h2>
    <p class="text-stone-600 max-w-3xl mt-6 text-left text-base tracking-wider">
      {description}
    </p>

    <div class="grid md:grid-cols-3 gap-4 mt-12">
      {
        items.map((card) => (
          <div class="relative w-full flex-col h-[600px]">
            <img
              src={card.image}
              alt={card.title}
              class="w-full h-full object-cover absolute inset-0 z-0"
            />
            <div class="absolute inset-0 bg-stone-950/50 z-10" />
            <div class="absolute bottom-0 p-4 pb-8 z-20">
              <h3 class="text-stone-100 text-center text-2xl font-bold font-secondary uppercase">
                {card.title}
              </h3>
              <p class="text-stone-200 text-sm tracking-wider text-center mt-2">
                {card.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
