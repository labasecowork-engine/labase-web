---
interface Step {
  label?: string;
  title?: string;
  description?: string;
}
interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  steps?: Step[];
}

const defaultSteps: Step[] = [
  {
    label: "PASO 1",
    title: "Transformar tu idea",
    description:
      "Validamos tu idea de negocio y desarrollamos un plan estratégico sólido para convertir tu visión en una empresa viable.",
  },
  {
    label: "PASO 2",
    title: "Validar en el mercado",
    description:
      "Te ayudamos a implementar metodologías de validación para obtener feedback real de usuarios y ajustar tu producto según las necesidades del mercado.",
  },
  {
    label: "PASO 3",
    title: "Escalar y crecer",
    description:
      "Te acompañamos en la expansión de tu negocio, optimizando procesos, aumentando la capacidad operativa y preparando tu empresa para el siguiente nivel de crecimiento.",
  },
];

const {
  eyebrow = "Incubación",
  title = "Desarrolla tu emprendimiento",
  description = "Nuestra fase de incubación está diseñada para convertir tu idea validada en un negocio operativo y sostenible. Te proporcionamos las herramientas, el espacio y el acompañamiento necesarios para desarrollar tu MVP y comenzar a generar tracción en el mercado.",
  steps,
} = Astro.props as Props;
const items = steps && steps.length > 0 ? steps : defaultSteps;
const bgs = ["bg-stone-800", "bg-stone-900", "bg-stone-950"];
const offsets = ["", "sm:mt-24", "sm:mt-48"];
---

<section class="pt-12 md:pt-24" role="region" aria-labelledby="incubation-title">
  <div class="max-w-7xl mx-auto w-full px-4 sm:px-8">
    <p class="text-stone-600 text-sm sm:text-lg tracking-[0.35em] uppercase mb-4 text-left">
      {eyebrow}
    </p>
    <h2
      id="incubation-title"
      class="text-stone-950 text-3xl sm:text-5xl font-bold font-secondary uppercase text-left max-w-5xl"
    >
      {title}
    </h2>
    <p class="text-stone-600 max-w-3xl mt-6 text-left text-sm sm:text-base tracking-wider">
      {description}
    </p>
    <div class="grid md:grid-cols-3 gap-4 mt-12 sm:mt-16" role="list">
      {
        items.map((step, i) => (
          <div
            class={`relative w-full flex h-[500px] sm:h-[600px] ${bgs[i] ?? "bg-stone-950"} ${offsets[i] ?? ""} p-8 justify-center items-center`}
            role="listitem"
          >
            <div>
              <p class="text-stone-100 text-base tracking-[0.35em] uppercase mb-4 text-center">
                {step.label}
              </p>
              <h3 class="text-stone-100 text-center text-xl sm:text-2xl font-bold font-secondary uppercase">
                {step.title}
              </h3>
              <p class="text-stone-200 text-xs sm:text-sm tracking-wider text-center mt-2">
                {step.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
