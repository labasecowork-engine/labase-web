---
interface Step {
  title?: string;
  description?: string;
  result?: string;
}
interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  image?: string;
  steps?: Step[];
}

const defaultSteps: Step[] = [
  {
    title: "Desplegar el pelotón",
    description:
      "Formamos un equipo multidisciplinario adaptado a las necesidades específicas de tu negocio, incorporando talento especializado en áreas clave como desarrollo tecnológico, marketing digital, ventas y operaciones.",
    result: "Creamos tu equipo de trabajo",
  },
  {
    title: "Ejecutar la táctica",
    description:
      "Implementamos estrategias de crecimiento acelerado, optimizando tus procesos de producción, mejorando la experiencia del cliente y desarrollando canales de distribución más eficientes para aumentar tu capacidad operativa.",
    result: "Aumentamos tu capacidad de producción",
  },
  {
    title: "Ajustes en el tiempo",
    description:
      "Realizamos análisis periódicos de métricas clave y resultados para identificar oportunidades de mejora, implementar ajustes estratégicos y mantener un crecimiento sostenible adaptado a las condiciones cambiantes del mercado.",
    result: "Maximizamos la productividad",
  },
];

const {
  eyebrow = "Aceleración",
  title = "Consolida tu misión y asegura tu expansión",
  description = "En la fase de aceleración, nos enfocamos en potenciar el crecimiento de tu empresa ya operativa. Trabajamos en optimizar procesos, escalar operaciones y desarrollar estrategias para aumentar tu participación en el mercado y atraer inversión para tu expansión.",
  image = "/images/emprendimiento/4.png",
  steps,
} = Astro.props as Props;
const items = steps && steps.length > 0 ? steps : defaultSteps;
---

<section
  class="py-12 md:py-24 mx-auto max-w-7xl w-full px-8 grid grid-cols-1 md:grid-cols-[400px_1fr] gap-14"
  aria-labelledby="acceleration-title"
  role="region"
>
  <img
    src={image}
    alt="Imagen ilustrativa del modelo de aceleración empresarial"
    class="w-full object-cover h-[600px] sm:h-full brightness-50"
    loading="lazy"
    decoding="async"
    fetchpriority="low"
  />
  <div class="pt-4 pb-12 sm:pb-0 sm:py-24">
    <p class="text-stone-600 text-sm sm:text-lg tracking-[0.35em] uppercase mb-4 text-left">
      {eyebrow}
    </p>
    <h3
      id="acceleration-title"
      class="text-stone-900 text-left text-3xl sm:text-5xl font-bold font-secondary uppercase"
    >
      {title}
    </h3>
    <p class="text-stone-600 text-sm sm:text-base tracking-wider text-left mt-2">
      {description}
    </p>
    <div class="flex flex-col gap-8 mt-12 sm:mt-16" role="list">
      {
        items.map((step) => (
          <div class="p-8 sm:p-14 bg-stone-100" role="listitem">
            <h2 class="text-stone-900 text-xl sm:text-2xl font-bold font-secondary uppercase">
              {step.title}
            </h2>
            <p class="text-stone-600 text-sm sm:text-base tracking-wider text-left mt-2">
              {step.description}
            </p>
            {step.result && (
              <span class="text-stone-900 text-sm sm:text-base font-bold tracking-wider text-left font-secondary mt-6 block">
                {step.result}
              </span>
            )}
          </div>
        ))
      }
    </div>
  </div>
</section>
