---
import { Image } from "@/components/ui";

interface MenuItem {
  name?: string;
  price?: string;
  note?: string;
}
interface MenuGroup {
  title?: string;
  items?: MenuItem[];
}
interface MenuColumn {
  title?: string;
  groups?: MenuGroup[];
}
interface Props {
  columns?: MenuColumn[];
}

const defaultColumns: MenuColumn[] = [
  {
    title: "Cafés",
    groups: [
      {
        title: "Clásicos",
        items: [
          { name: "Café pasado", price: "S/ 5.00" },
          { name: "Leche + Milo", price: "S/ 5.50" },
          { name: "Americano", price: "S/ 7.00" },
          { name: "Capuchino", price: "S/ 10.00" },
          { name: "Leche caliente", price: "S/ 6.00" },
          { name: "Expreso", price: "S/ 6.00" },
          { name: "Latte", price: "S/ 10.00" },
          { name: "Infusiones (varios)", price: "S/ 2.50" },
        ],
      },
      {
        title: "Frapuchinos",
        items: [
          { name: "Fresa / Chocolate / Oreo", price: "S/ 12.00" },
          { name: "Tradicional", price: "S/ 10.00" },
        ],
      },
      {
        title: "Milkshake",
        items: [
          { name: "Chocolate / Vainilla / Fresa / Lúcuma", price: "S/ 12.00" },
        ],
      },
    ],
  },
  {
    title: "Jugos",
    groups: [
      {
        title: "Clásicos",
        items: [
          { name: "Papaya / Piña / Plátano", price: "S/ 6.50" },
          { name: "Fresa", price: "S/ 8.50" },
          { name: "Naranja", price: "S/ 7.00" },
          { name: "Plátano + leche", price: "S/ 8.00" },
          { name: "Fresa + leche", price: "S/ 10.00" },
          { name: "Papaya + leche", price: "S/ 8.00" },
        ],
      },
      {
        title: "Jugos Energéticos",
        items: [
          { name: "Digestivo", price: "S/ 6.00", note: "(apio, pepino, perejil, manzana verde)" },
          { name: "Amanecer", price: "S/ 10.00", note: "(arándanos, mora, espinaca)" },
          { name: "Fantástico", price: "S/ 10.00", note: "(banana, nueces, linaza, leche, coco)" },
          { name: "Belleza", price: "S/ 8.00", note: "(zanahoria, sábila, pepino, menta)" },
        ],
      },
    ],
  },
  {
    title: "Postres",
    groups: [
      {
        title: "Salados",
        items: [
          { name: "Sándwich doble (queso y jamón)", price: "S/ 3.50" },
          { name: "Sándwich triple (pollo, jamón y queso)", price: "S/ 5.00" },
          { name: "Pan pequeño de queso", price: "S/ 4.00" },
          { name: "Empanada", price: "S/ 4.00" },
        ],
      },
      {
        title: "Dulces",
        items: [
          { name: "Waffles (clásico / fresa / chocolate)", price: "S/ 8-10" },
          { name: "Crepas (clásica / fresa / chocolate)", price: "S/ 8-10" },
          { name: "Pie de piña / Alfajor", price: "S/ 2.00" },
          { name: "2 bolas de helado (varios)", price: "S/ 5.00" },
          { name: "Mousse de arándanos", price: "S/ 8.00", note: "(Leche, yogurt griego, chía, arándanos)" },
        ],
      },
    ],
  },
  {
    title: "Desayunos",
    groups: [
      {
        title: "Nutritivos",
        items: [
          { name: "Desayuno Americano", price: "S/ 10.00", note: "Tostada + palta + jamón + café pasado + jugo" },
          { name: "Pancakes Banana", price: "S/ 8.00", note: "Plátano + leche + huevo + panqueque de trigo + miel + frita" },
          { name: "Desayuno El Arsenal", price: "S/ 12.00", note: "Tostada + huevo frito + fruta picada + café pasado + jugo" },
        ],
      },
      {
        title: "Extras",
        items: [
          { name: "Pan / tostada + palta", price: "S/ 3.00" },
          { name: "Pan / tostada + jamonada", price: "S/ 2.50" },
          { name: "Pan / tostada + mermelada", price: "S/ 2.00" },
          { name: "Pan / tostada + mantequilla", price: "S/ 2.00" },
          { name: "Yogurt personal (vaso)", price: "S/ 3.00" },
          { name: "Yogurt griego + granola (vaso)", price: "S/ 4.50" },
        ],
      },
    ],
  },
];

const { columns } = Astro.props as Props;
const cols = columns && columns.length > 0 ? columns : defaultColumns;
const firstHalf = cols.slice(0, 2);
const secondHalf = cols.slice(2);
---

<section class="py-24 bg-gray-50 text-stone-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-20 gap-y-16">
      {
        firstHalf.map((col) => (
          <div class="space-y-10">
            <h3 class="text-4xl font-secondary text-[#82674E] mb-8">
              {col.title}
            </h3>
            {(col.groups ?? []).map((group) => (
              <div>
                <h4 class="text-xl font-semibold uppercase tracking-wider text-stone-800 mb-5">
                  {group.title}
                </h4>
                <div class="space-y-4 text-stone-700">
                  {(group.items ?? []).map((item) => (
                    <div class="flex flex-col">
                      <div class="flex justify-between items-baseline">
                        <span class={item.note ? "font-semibold" : ""}>
                          {item.name}
                        </span>
                        {!item.note && (
                          <div class="flex-grow border-b border-dashed border-stone-300 mx-3" />
                        )}
                        <span class="font-medium text-[#82674E] whitespace-nowrap">
                          {item.price}
                        </span>
                      </div>
                      {item.note && (
                        <p class="text-sm text-stone-500 mt-1">{item.note}</p>
                      )}
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        ))
      }
    </div>

    {
      secondHalf.length > 0 && (
        <>
          <div class="flex justify-center py-20">
            <Image
              client:only="react"
              src="/images/arsenal/line-decorative.svg"
              alt="Línea decorativa"
              className="w-48"
              loading="lazy"
              decoding="async"
            />
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-20 gap-y-16">
            {secondHalf.map((col) => (
              <div class="space-y-10">
                <h3 class="text-4xl font-secondary text-[#82674E] mb-8">
                  {col.title}
                </h3>
                {(col.groups ?? []).map((group) => (
                  <div>
                    <h4 class="text-xl font-semibold uppercase tracking-wider text-stone-800 mb-5">
                      {group.title}
                    </h4>
                    <div class="space-y-4 text-stone-700">
                      {(group.items ?? []).map((item) => (
                        <div class="flex flex-col">
                          <div class="flex justify-between items-baseline">
                            <span class={item.note ? "font-semibold" : ""}>
                              {item.name}
                            </span>
                            {!item.note && (
                              <div class="flex-grow border-b border-dashed border-stone-300 mx-3" />
                            )}
                            <span class="font-medium text-[#82674E] whitespace-nowrap">
                              {item.price}
                            </span>
                          </div>
                          {item.note && (
                            <p class="text-sm text-stone-500 mt-1">
                              {item.note}
                            </p>
                          )}
                        </div>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            ))}
          </div>
        </>
      )
    }
  </div>
</section>
